# Backend selection: fake | anthropic | local
LLM_BACKEND=fake

# Anthropic API (required only when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Local llama-server / Ollama (required only when LLM_BACKEND=local)
# Must be OpenAI-compatible endpoint (path ending in /v1)
LOCAL_LLM_URL=http://192.168.3.92:8080/v1
LOCAL_LLM_MODEL=Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf

DATABASE_URL=sqlite:///./storyteller.db
MEM0_STORAGE_PATH=./.mem0_data
LOG_LEVEL=INFO
